# Relational Database Parameters (Loaded by docker-compose)
POSTGRES_USER=twin_operator
POSTGRES_PASSWORD=YOUR_PASSWORD
POSTGRES_DB=digital_twin

# Connection Strings
DATABASE_URL=postgresql://twin_operator:YOUR_PASSWORD@localhost:5432/digital_twin?schema=public
REDIS_URL=redis://localhost:6379
MQTT_BROKER_URL=mqtt://localhost:1883

# Server parameters
PORT=5000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here

# Timeout settings
HEARTBEAT_TIMEOUT_MS=60000

# Alarm Thresholds
THRESHOLD_TEMPERATURE=80.0
THRESHOLD_VIBRATION=5.0

# Frontend configurations
VITE_API_URL=/api
VITE_WS_URL=/

# Allowed CORS Origin for production environments
ALLOWED_ORIGIN=http://localhost:3000

